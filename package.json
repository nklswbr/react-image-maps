{
  "name": "react-image-maps",
  "version": "0.1.2",
  "description": "Responsive HTML image maps for React",
  "source": "src/index.tsx",
  "main": "dist/index.js",
  "module": "dist/index.module.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.module.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "microbundle --jsx React.createElement",
    "dev": "microbundle watch --jsx React.createElement",
    "prepare": "npm run build"
  },
  "keywords": [
    "react",
    "image-map",
    "image-maps",
    "html",
    "responsive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nklswbr/react-image-maps"
  },
  "homepage": "https://github.com/nklswbr/react-image-maps#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "microbundle": "^0.15.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
